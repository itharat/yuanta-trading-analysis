ui <- navbarPage(
title = "Trading Analytics Dashboard",
# 🏠 HOME PAGE
tabPanel("Home",
fluidPage(
br(),
h2("Welcome to Trading Analytics Dashboard"),
p("Use this dashboard to explore trading behavior, client segmentation, and revenue insights."),
br(),
h4("Sections"),
tags$ul(
tags$li("Top Stocks & Sector Distribution"),
tags$li("Client Distribution"),
tags$li("Channel Usage"),
tags$li("Outlier Detection"),
tags$li("Commission Trends")
)
)
),
# 📊 1. TOP STOCKS + SECTOR
tabPanel("Market Overview",
fluidPage(
br(),
h3("Top 10 Traded Stocks"),
plotOutput("topStocksPlot"),
br(),
h3("Sector Distribution"),
plotOutput("sectorPie"),
br(),
h4("Insights"),
p("Identify which stocks and sectors dominate trading activity. High concentration may indicate market preference or speculation.")
)
),
# 👥 2. CLIENT DISTRIBUTION
tabPanel("Client Analysis",
fluidPage(
br(),
h3("Clients by Segment and Region"),
plotOutput("clientDistPlot"),
br(),
h3("Top Provinces in South (Retail)"),
plotOutput("southPlot"),
br(),
h4("Insights"),
p("Understand geographic and segment distribution. Regional clustering can inform targeted marketing strategies.")
)
),
# 📡 3. CHANNEL USAGE
tabPanel("Channel Usage",
fluidPage(
br(),
h3("Channel Usage Count"),
plotOutput("channelCountPlot"),
br(),
h3("Channel Trading Value"),
plotOutput("channelValuePlot"),
br(),
h4("Insights"),
p("Analyze which platforms drive activity and value. Useful for optimizing digital vs broker channels.")
)
),
# 🚨 4. OUTLIERS
tabPanel("Outlier Detection",
fluidPage(
br(),
h3("Trading Value Distribution"),
plotOutput("boxplot"),
br(),
h4("Insights"),
p("Outliers represent high-value traders. These clients are critical but may increase revenue concentration risk.")
)
),
# 📈 5. COMMISSION TREND
tabPanel("Commission Trends",
fluidPage(
br(),
h3("Commission by Segment"),
plotOutput("commissionSegment"),
br(),
h3("Commission by Region"),
plotOutput("commissionRegion"),
br(),
h4("Insights"),
p("Track revenue trends over time. Helps identify growth segments and seasonal patterns.")
)
)
)
